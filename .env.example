# ══════════════════════════════════════════════════════════════
# Ablox — Environment Variables Template
# Copy this file to .env and fill in your values
# In Docker: DATABASE_URL and REDIS_URL are overridden by docker-compose.yml
# ══════════════════════════════════════════════════════════════

# ── Domain (used by Traefik for SSL) ──
DOMAIN=mrco.live
ACME_EMAIL=info@mrco.live

# ── Database ──
POSTGRES_DB=ablox
POSTGRES_USER=ablox_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ablox_admin:CHANGE_ME@localhost:5432/ablox

# ── Redis ──
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_PORT=6379
REDIS_URL=redis://:CHANGE_ME@localhost:6379

# ── Session (generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))") ──
SESSION_SECRET=CHANGE_ME_64_CHAR_RANDOM

# ── Server ──
NODE_ENV=development
PORT=3000
APP_PORT=3000

# ── Database Pool ──
DB_POOL_MAX=20

# ── Logging (trace|debug|info|warn|error|fatal) ──
LOG_LEVEL=info

# ── JWT (generate same as session secret) ──
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM
JWT_EXPIRES_IN=7d

# ── CORS (REQUIRED in production) ──
CORS_ORIGIN=https://mrco.live

# ── Encryption (AES-256-GCM key — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ──
# REQUIRED in production — server will NOT start without it
ENCRYPTION_SECRET=CHANGE_ME_64_HEX_CHARS

# ── Admin defaults ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── SMTP / Email (OTP & Password Reset) ──
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@mrco.live
SMTP_PASS=CHANGE_ME_EMAIL_PASSWORD
SMTP_SENDER_NAME=Ablox
SMTP_SENDER_EMAIL=info@mrco.live

# ── TWA / Android App (PWABuilder) ──
# SHA-256 fingerprint from your signing key (keytool or PWABuilder)
# TWA_SHA256_FINGERPRINT=AA:BB:CC:...
# SHA-256 from Google Play App Signing (if uploaded to Play Store)
# PLAY_SHA256_FINGERPRINT=DD:EE:FF:...
# Android package name
TWA_PACKAGE_NAME=app.ablox.twa

# ── Apple iOS App (Universal Links) ──
# Your Apple Developer Team ID
# APPLE_TEAM_ID=XXXXXXXXXX
# Your iOS app bundle identifier
# APPLE_BUNDLE_ID=app.ablox.ios
